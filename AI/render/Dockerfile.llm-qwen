# Render: Root Directory = AI | Dockerfile Path = render/Dockerfile.llm-qwen
# Qwen2.5-0.5B-Instruct Q4_K_S (~368MB) — use Instruct, not 0.2B base
FROM alpine:3.20 AS model
RUN apk add --no-cache curl
RUN mkdir -p /models \
 && curl -fsSL -o /models/model.gguf \
  "https://huggingface.co/second-state/Qwen2.5-0.5B-Instruct-GGUF/resolve/main/Qwen2.5-0.5B-Instruct-Q4_K_S.gguf"

FROM --platform=linux/amd64 ghcr.io/ggml-org/llama.cpp:server
COPY --from=model /models/model.gguf /models/model.gguf
COPY shared/start-llama.sh /start-llama.sh
RUN chmod +x /start-llama.sh
WORKDIR /app
ENV LLAMA_CTX=2048 LLAMA_THREADS=2 LLAMA_BATCH=128
EXPOSE 10000
ENTRYPOINT ["/start-llama.sh"]

# Copy to AI/.env or repo root .env for docker compose:
#   docker compose -f AI/docker-compose.yml --env-file AI/.env up --build
#
# Local stub mode (no Docker): run-local.ps1 uses defaults below.

# =============================================================================
# ai-gateway (port 8898) — your backend / Swagger calls THIS service only
# =============================================================================
AI_SERVICE_INTERNAL_API_KEY=dev-internal-ai-key
AI_DEFAULT_LLM=smol
# Chat speed: fast (default) = lite prompt + 128 tok cap; full = longer tutor prompts
AI_CHAT_MODE=fast
AI_STRUCTURE_INPUT=true
AI_PREPROCESS_INPUT=true
# micro | lite | full — micro = fewest system prompt tokens (default)
AI_SYSTEM_PROMPT_LEVEL=micro
AI_USER_TURN_PREFIX=false
AI_MAX_USER_CHARS=800
AI_MAX_ASSISTANT_CHARS=400
AI_MAX_SYSTEM_CHARS=1200
AI_DOC_EXCERPT_MAX=3
AI_DOC_EXCERPT_CHARS=200
AI_CHARS_PER_TOKEN_EST=4
# Summarize older turns when prompt exceeds budget (extra LLM call)
AI_CONTEXT_SUMMARIZE=true
AI_CONTEXT_SUMMARIZE_MIN_MSGS=4
AI_CONTEXT_SUMMARIZE_KEEP_MSGS=4
AI_CONTEXT_SUMMARIZE_MAX_TOKENS=72
AI_CONTEXT_SUMMARY_MAX_CHARS=320
# Set true to skip LLM summary (fast, lower quality)
AI_CONTEXT_SUMMARIZE_EXTRACTIVE_ONLY=false
AI_FAST_MAX_TOKENS=128
AI_CHAT_HISTORY_MAX_TURNS=4
AI_FAST_MINIMAL_CONTEXT=true
AI_MAX_TOKENS=512
AI_TEMPERATURE=0.7
AI_TOP_P=0.9
AI_TOP_K=40
AI_REPEAT_PENALTY=1.15
AI_FREQUENCY_PENALTY=0.1
# AI_TEMPLATES_DIR=/app/templates   # set in Docker image; override only if needed

# Gateway → LLM backends
# Docker Compose (same network):
# LLM_SMOL_URL=http://llm-smol:8080
# LLM_QWEN_URL=http://llm-qwen:8080
#
# Render.com — set on service **dev-together-ai-gateway** only (NOT smol/qwen services).
# Environment Groups: must be *linked* to the gateway service, then redeploy.
# A "global" group alone does not inject vars until linked per service.
LLM_SMOL_URL=https://dev-together-ai-smol.onrender.com
LLM_QWEN_URL=https://dev-together-ai-qwen.onrender.com
#
# Local stubs (run-local.ps1):
# LLM_SMOL_URL=http://127.0.0.1:8896
# LLM_QWEN_URL=http://127.0.0.1:8897

# Gateway → Workflow (optional: persist quiz / flashcards / mindmap / event / summary)
WORKFLOW_SERVICE_BASE_URL=http://host.docker.internal:8882
WORKFLOW_SERVICE_INTERNAL_API_KEY=dev-internal-workflow-key

# =============================================================================
# llm-smol + llm-qwen (llama.cpp) — ports 8896 / 8897 on host
# =============================================================================
PORT=8080
# LLM containers (dev-together-ai-smol / dev-together-ai-qwen) — lower = faster on 512MB CPU
LLAMA_CTX=1024
LLAMA_THREADS=2
LLAMA_BATCH=512
LLAMA_CACHE_TYPE_K=q8_0
LLAMA_CACHE_TYPE_V=q8_0
# smol only (~100MB model): keep weights in RAM
LLAMA_MLOCK=1
LLAMA_TEMP=0.7
LLAMA_TOP_P=0.9
LLAMA_TOP_K=40
LLAMA_REPEAT_PENALTY=1.15
# LLAMA_MODEL_PATH=/models/model.gguf

# =============================================================================
# Java backend (when wiring Workflow/Auth to AI gateway)
# =============================================================================
# AI_SERVICE_BASE_URL=http://localhost:8898

# Copy to EXE101-BE/.env — keys mirror BE/*/application-*.properties (${VAR} placeholders).
AUTH_ISSUER_URI=http://localhost:8880

UNDERTOW_ACCESSLOG_ENABLED=false
UNDERTOW_ACCESSLOG_PATTERN=%h %l %u %t "%r" %s %b
UNDERTOW_IO_THREADS=4
UNDERTOW_WORKER_THREADS=32
UNDERTOW_MAX_HTTP_POST_SIZE=10485760

DB_URL=jdbc:postgresql://HOST:PORT/DATABASE?sslmode=require
DB_USERNAME=
DB_PASSWORD=

DB_IDLE_TIMEOUT=30000
DB_MAXIMUM_POOL_SIZE=15
DB_MINIMUM_IDLE=2
DB_CONNECTION_TIMEOUT=20000
DB_MAX_LIFETIME=1800000

DB_FLYWAY_ENABLED=true
DB_FLYWAY_BASELINE_ON_MIGRATE=true

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Email microservice (SMTP) + auth HTTP client (dev/prod auth profile)
EMAIL_SERVICE_BASE_URL=http://localhost:8895
EMAIL_SERVICE_INTERNAL_API_KEY=
APP_FRONTEND_PUBLIC_BASE_URL=http://localhost:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# On-device LLMs (llama.cpp, ~300MB idle each on Render 512MB)
LLAMA_CTX=256
LLAMA_THREADS=2
LLAMA_BATCH=128

# AI gateway (port 8898) — backend calls this
AI_SERVICE_BASE_URL=http://localhost:8898
AI_SERVICE_INTERNAL_API_KEY=dev-internal-ai-key
AI_DEFAULT_LLM=smol
AI_MAX_TOKENS=256
LLM_SMOL_URL=http://localhost:8896
LLM_QWEN_URL=http://localhost:8897

# AI gateway → workflow Apply (persist quiz, flashcards, mindmap, schedule, summary)
WORKFLOW_SERVICE_BASE_URL=http://localhost:8882
WORKFLOW_SERVICE_INTERNAL_API_KEY=dev-internal-workflow-key

LOGGING_LEVEL_SPRING_SECURITY=INFO

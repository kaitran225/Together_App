# Copy this file to `.env` (same folder as docker-compose.yml) and fill in real values.
# `.env` is read automatically by `docker compose`. Never commit the filled-in `.env`.

# ── Domain (DuckDNS or a real domain you control) ─────────────────────────
# If using DuckDNS: DOMAIN=<subdomain>.duckdns.org and DUCKDNS_SUBDOMAIN=<subdomain> (no suffix)
DOMAIN=your-subdomain.duckdns.org
DUCKDNS_SUBDOMAIN=your-subdomain
DUCKDNS_TOKEN=
# Used only by deploy/certbot/init-letsencrypt.sh (cert-expiry notices go here; optional)
LETSENCRYPT_EMAIL=
# Set to 1 the first time you run init-letsencrypt.sh to test against Let's Encrypt's
# staging server (no rate limits, but browsers won't trust the cert). Set back to 0 for real.
LETSENCRYPT_STAGING=0

# ── Postgres (single instance, schemas "auth" and "workflow" are auto-created by Flyway) ──
DB_ROOT_USERNAME=postgres
DB_ROOT_PASSWORD=change-me-strong-password

# ── Auth service ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800
OAUTH2_CLIENT_SECRET={noop}change-me
# Gemini fallback used by the auth module's own ai.* config (separate from workflow's Ollama integration)
AI_PROVIDER=gemini
AI_MODEL=gemini-2.0-flash
AI_API_KEY=
AI_BASE_URL=https://generativelanguage.googleapis.com
AI_ENABLED=true

# ── Email service (SMTP) ────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
# Shared secret auth/workflow use to call the internal email service — any random string, must match across services
EMAIL_SERVICE_INTERNAL_API_KEY=change-me-internal-key

# ── STUN/TURN (coturn) — must match deploy/coturn/turnusers.txt ────────────
TURN_USERNAME=testuser
TURN_CREDENTIAL=change-me-strong-password

# ── AI gateway (speech-to-text -> LLM meeting summary / task suggestion, quiz-from-doc) ──
# This is the separate "custom AI server" referenced in workflow's AiServiceClient — not
# part of this repo. Leave the Render default unless you also self-host that gateway.
AI_SERVICE_URL=https://dev-together-ai-gateway.onrender.com/

# ── PayOS payment gateway ───────────────────────────────────────────────────
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
